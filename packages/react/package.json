{
	"name": "@acdh-oeaw/react-ui",
	"version": "0.0.0",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"src",
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup ./src/index.ts",
		"format:check": "prettier . --cache --check --ignore-path ../../.gitignore",
		"format:fix": "pnpm run format:check --write",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --cache --ignore-path ../../.gitignore",
		"lint:code:fix": "pnpm run lint:code:check --fix",
		"lint:styles:check": "stylelint \"./**/*.css\" --cache --ignore-path ../../.gitignore",
		"lint:styles:fix": "pnpm run lint:styles:check --fix",
		"storybook:build": "storybook build",
		"storybook:dev": "storybook dev --no-open --port 6006",
		"storybook:test": "test-storybook",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^1.0.5",
		"@acdh-oeaw/eslint-config-react": "^1.0.6",
		"@acdh-oeaw/eslint-config-storybook": "^1.0.5",
		"@acdh-oeaw/lib": "^0.1.6",
		"@acdh-oeaw/stylelint-config": "^2.0.1",
		"@acdh-oeaw/tsconfig-lib": "^1.0.1",
		"@fontsource-variable/inter": "^5.0.16",
		"@react-aria/optimize-locales-plugin": "^1.0.1",
		"@storybook/addon-a11y": "^7.6.10",
		"@storybook/addon-essentials": "^7.6.10",
		"@storybook/addon-interactions": "^7.6.10",
		"@storybook/addon-links": "^7.6.10",
		"@storybook/addon-onboarding": "^1.0.10",
		"@storybook/addon-storysource": "^7.6.10",
		"@storybook/addon-themes": "^7.6.10",
		"@storybook/blocks": "^7.6.10",
		"@storybook/react": "^7.6.10",
		"@storybook/react-vite": "^7.6.10",
		"@storybook/test": "^7.6.10",
		"@storybook/test-runner": "^0.16.0",
		"@storybook/theming": "^7.6.10",
		"@storybook/types": "^7.6.10",
		"@types/react": "^18.2.48",
		"@vitejs/plugin-react-swc": "^3.5.0",
		"axe-core": "^4.8.3",
		"axe-playwright": "^2.0.1",
		"cva": "^1.0.0-beta.1",
		"eslint": "^8.56.0",
		"eslint-plugin-tailwindcss": "^3.14.0",
		"lucide-react": "^0.312.0",
		"react": "^18.2.0",
		"react-aria-components": "^1.0.1",
		"storybook": "^7.6.10",
		"stylelint": "^16.2.0",
		"tailwind-merge": "^2.2.0",
		"tailwindcss": "^3.4.1",
		"tailwindcss-animate": "^1.0.7",
		"tailwindcss-react-aria-components": "^1.0.0",
		"tsup": "^8.0.1",
		"typescript": "^5.3.3",
		"use-intl": "^3.4.5",
		"vite": "^5.0.11",
		"vite-tsconfig-paths": "^4.3.1"
	},
	"browserslist": {
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		],
		"production": [
			">=0.75%",
			"not dead",
			"not op_mini all"
		]
	},
	"eslintConfig": {
		"ignorePatterns": [
			"!.storybook"
		],
		"extends": [
			"@acdh-oeaw/eslint-config",
			"@acdh-oeaw/eslint-config/strict",
			"@acdh-oeaw/eslint-config-react",
			"@acdh-oeaw/eslint-config-storybook",
			"plugin:eslint-plugin-tailwindcss/recommended"
		],
		"settings": {
			"tailwindcss": {
				"callees": [
					"cn",
					"variants"
				]
			}
		},
		"rules": {
			"arrow-body-style": [
				"error",
				"always"
			],
			"prefer-arrow-callback": [
				"error",
				{
					"allowNamedFunctions": true
				}
			],
			"@typescript-eslint/explicit-module-boundary-types": "error",
			"@typescript-eslint/strict-boolean-expressions": "error"
		}
	},
	"lint-staged": {
		"*.@(ts|tsx)": [
			"eslint --cache --fix",
			"prettier --cache --write"
		],
		"*.@(css)": [
			"stylelint --cache --fix",
			"prettier --cache --write"
		],
		"*.!(css|ts|tsx)": "prettier --cache --ignore-unknown --write"
	},
	"postcss": {
		"plugins": {
			"tailwindcss": {}
		}
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	}
}
