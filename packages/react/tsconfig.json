{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@acdh-oeaw/tsconfig-lib",
	"compilerOptions": {
		"baseUrl": ".",
		"exactOptionalPropertyTypes": false,
		/** @see https://github.com/egoist/tsup/issues/884 */
		"incremental": false,
		"module": "esnext",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["./**/*.ts", "./**/*.tsx", "./.storybook/**/*.ts", "./.storybook/**/*.tsx"],
	"exclude": ["dist", "node_modules", "storybook-static"],
	"mdx": {
		"plugins": []
	}
}
