{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@acdh-oeaw/tsconfig-lib",
	"compilerOptions": {
		"baseUrl": ".",
		"exactOptionalPropertyTypes": false,
		"module": "esnext",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"exclude": ["dist", "node_modules", "storybook-static"],
	"mdx": {
		"plugins": []
	}
}
