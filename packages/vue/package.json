{
	"name": "@acdh-oeaw/vue-ui",
	"version": "0.0.0",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist",
		"src"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup ./src/index.ts",
		"format:check": "prettier . --cache --check --ignore-path ../../.gitignore",
		"format:fix": "pnpm run format:check --write",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --cache --ignore-path ../../.gitignore",
		"lint:code:fix": "pnpm run lint:code:check --fix",
		"lint:styles:check": "stylelint \"./**/*.@(css|vue)\" --cache --ignore-path ../../.gitignore",
		"lint:styles:fix": "pnpm run lint:styles:check --fix",
		"storybook:build": "storybook build",
		"storybook:dev": "storybook dev --no-open --port 6006",
		"storybook:test": "test-storybook",
		"types:check": "tsc --noEmit"
	},
	"peerDependencies": {
		"@acdh-oeaw/tailwindcss-preset": "^0.0.22",
		"@ark-ui/vue": "^0.11.0",
		"cva": "^1.0.0",
		"lucide-vue-next": "*",
		"tailwind-merge": "^2.0.0",
		"tailwindcss": "^3.4.0"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^1.0.7",
		"@acdh-oeaw/eslint-config-storybook": "^1.0.7",
		"@acdh-oeaw/eslint-config-vue": "^1.0.12",
		"@acdh-oeaw/lib": "^0.1.7",
		"@acdh-oeaw/stylelint-config": "^2.0.1",
		"@acdh-oeaw/tailwindcss-preset": "^0.0.22",
		"@acdh-oeaw/tsconfig-lib": "^1.0.1",
		"@ark-ui/vue": "^0.11.0",
		"@fontsource-variable/inter": "^5.0.17",
		"@storybook/addon-a11y": "^8.0.1",
		"@storybook/addon-essentials": "^8.0.1",
		"@storybook/addon-interactions": "^8.0.1",
		"@storybook/addon-links": "^8.0.1",
		"@storybook/addon-onboarding": "^8.0.1",
		"@storybook/addon-storysource": "^8.0.1",
		"@storybook/addon-themes": "^8.0.1",
		"@storybook/blocks": "^8.0.1",
		"@storybook/test": "^8.0.1",
		"@storybook/test-runner": "^0.17.0",
		"@storybook/theming": "^8.0.1",
		"@storybook/types": "^8.0.1",
		"@storybook/vue3": "^8.0.1",
		"@storybook/vue3-vite": "^8.0.1",
		"@vitejs/plugin-vue": "^5.0.4",
		"axe-core": "^4.8.4",
		"axe-playwright": "^2.0.1",
		"cva": "^1.0.0-beta.1",
		"eslint": "^8.57.0",
		"eslint-plugin-tailwindcss": "^3.15.1",
		"lucide-vue-next": "^0.359.0",
		"storybook": "^8.0.1",
		"stylelint": "^16.2.1",
		"tailwind-merge": "^2.2.2",
		"tailwindcss": "^3.4.1",
		"tsup": "^8.0.2",
		"typescript": "^5.4.2",
		"vite": "^5.1.6",
		"vite-tsconfig-paths": "^4.3.2",
		"vue-i18n": "^9.10.2"
	},
	"eslintConfig": {
		"ignorePatterns": [
			"!.storybook"
		],
		"extends": [
			"@acdh-oeaw/eslint-config",
			"@acdh-oeaw/eslint-config/strict",
			"@acdh-oeaw/eslint-config-vue",
			"@acdh-oeaw/eslint-config-storybook",
			"plugin:eslint-plugin-tailwindcss/recommended"
		],
		"settings": {
			"tailwindcss": {
				"callees": [
					"cn",
					"variants"
				]
			}
		},
		"rules": {
			"arrow-body-style": [
				"error",
				"always"
			],
			"prefer-arrow-callback": [
				"error",
				{
					"allowNamedFunctions": true
				}
			],
			"@typescript-eslint/explicit-module-boundary-types": "error",
			"@typescript-eslint/strict-boolean-expressions": "error"
		}
	},
	"lint-staged": {
		"*.@(ts|tsx)": [
			"eslint --cache --fix",
			"prettier --cache --write"
		],
		"*.@(css)": [
			"stylelint --cache --fix",
			"prettier --cache --write"
		],
		"*.@(vue)": [
			"eslint --cache --fix",
			"stylelint --cache --fix",
			"prettier --cache --write"
		],
		"*.!(css|ts|tsx|vue)": "prettier --cache --ignore-unknown --write"
	},
	"postcss": {
		"plugins": {
			"tailwindcss": {}
		}
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	}
}
